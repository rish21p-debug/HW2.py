    '''
    CREDIT_PRICE = 1000
    
    def __init__(self, student):
        # Task: To set up a new account for a student.
        # Input: student - the Student object who owns this account.
        # Output: None.
        # How: Saves the student's info, sets their balance to 0, and creates an empty dictionary for loans.
        self.student = student
        self.balance = 0
        self.loans = {}


    def __str__(self):
        # Task: Show the student's account info as text.
        # Input: None.
        # Output: A string with the name, ID, and balance.
        # How: Converts the balance to a clean string format and prints out the account details.
        bal_str = f"{self.balance:g}" if isinstance(self.balance, float) else str(self.balance)
        return f"Name: {self.student.name}\nID: {self.student.id}\nBalance: ${bal_str}"

    __repr__ = __str__


    def makePayment(self, amount):
        # Task: Make a payment on the student's account.
        # Input: amount as an integer or float.
        # Output: The new balance.
        # How: Subtracts the payment amount from the balance.
        self.balance -= amount
        return self.balance


    def chargeAccount(self, amount):
        # Task: Charge the student's account.
        # Input: amount as an integer or float.
        # Output: The updated balance.
        # How: Adds the charge amount to the balance.
        self.balance += amount
        return self.balance




