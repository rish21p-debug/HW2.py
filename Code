        >>> s1.classCode
        'Sophomore'
    '''
    def __init__(self, name, ssn, year):
        random.seed(1)
        # Task: To set up a full student profile with a billing account.
        # Input: name (str), ssn (str), year (str).
        # Output: None.
        # How: Sets up personal fields using super(), opens a blank semester list, and creates a student account.
        super().__init__(name, ssn)
        self.classCode = year
        self.semesters = {}
        self.hold = False
        self.active = True
        self.account = self.__createStudentAccount()


    def __str__(self):
        # Task: To return a summary string of the student.
        # Input: None.
        # Output: A string containing student details.
        # How: Combines the student's name, calculated system ID, and current class year code.
        return f"Student({self.name}, {self.id}, {self.classCode})"

    __repr__ = __str__

    def __createStudentAccount(self):
        # Task: To create a student account.
        # Input: None.
        # Output: A StudentAccount object or None.
        # How: Returns a new StudentAccount object that is linked to the student if they are active, otherwise it returns None.
        if self.active:
            return StudentAccount(self)
        return None


    @property
    def id(self):
        # Task: To create the student's system ID.
        # Input: None.
        # Output: A string representing the student's ID.
        # How: Combines the student's initials with the last four digits of their SSN.
        names = self.name.split()
        initials = ""
        for n in names:
            if n:
                initials += n[0].lower()
        last_four = self.get_ssn()[-4:]
        return f"{initials}{last_four}"

    def registerSemester(self):
        # Task: To open a new blank semester for the student.
        # Input: None.
        # Output: An error string or None.
        # How: Checks if the student is active and clear of holds, picks the next number key, and updates their class level.
        if not self.active or self.hold:
            return "Unsuccessful operation"
        if not self.semesters:
            next_key = 1
        else:
            next_key = max(self.semesters.keys()) + 1
        self.semesters[next_key] = Semester()
        
        num_sems = len(self.semesters)
        if num_sems in (1, 2):
            self.classCode = "Freshman"
        elif num_sems in (3, 4):
            self.classCode = "Sophomore"
        elif num_sems in (5, 6):
            self.classCode = "Junior"
        elif num_sems > 6:
            self.classCode = "Senior"



    def enrollCourse(self, cid, catalog):
        # Task: To add a class to the student's current semester list.
        # Input: cid (str), catalog( the master Catalog object).
        # Output: A string message showing the result.
        # How: Ignores extra spaces to find a catalog match, then checks for duplicates, adds the class object, and charges their account.
        if not self.active or self.hold:
            return "Unsuccessful operation"
        
        target_cid = None
        for key in catalog.courseOfferings:
            if key.replace(" ", "") == cid.replace(" ", ""):
                target_cid = key
                break
                
        if target_cid is None:
            return "Course not found"
        if not self.semesters:
            return "Unsuccessful operation"
        
        current_sem_key = max(self.semesters.keys())
        current_semester = self.semesters[current_sem_key]
        course_obj = catalog.courseOfferings[target_cid]
        
        if course_obj.cid in current_semester.courses:
            return "Course already enrolled"
            
        current_semester.addCourse(course_obj)
        cost = course_obj.credits * StudentAccount.CREDIT_PRICE
        self.account.chargeAccount(cost)
        return "Course added successfully"

    def dropCourse(self, cid):
        # Task: To remove a course from the current semester and handle a refund.
        # Input: cid (str).
        # Output: A string that showing the result.
        # How: Looks up the class in the active term, removes it, and pays back half the cost.
        if not self.active or self.hold:
            return "Unsuccessful operation"
        if not self.semesters:
            return "Course not found"
            
        current_sem_key = max(self.semesters.keys())
        current_semester = self.semesters[current_sem_key]
        
        target_cid = None
        for key in current_semester.courses:
            if key.replace(" ", "") == cid.replace(" ", ""):
                target_cid = key
                break
                
        if target_cid is None:
            return "Course not found"
            
        course_obj = current_semester.courses[target_cid]
        current_semester.dropCourse(course_obj)
        refund = (course_obj.credits * StudentAccount.CREDIT_PRICE) / 2.0
        self.account.makePayment(refund)
        return "Course dropped successfully"

    def getLoan(self, amount):
        # Task: To give a student financial loan money if they qualify.
        # Input: amount as an integer or float.
        # Output: A string.
        # How: Checks if the schedule is full-time, then makes a new Loan object, saves it, and subtracts the money from their bill.
        if not self.active:
            return "Unsuccessful operation"
        if not self.semesters:
            return "Not full-time"
            
        current_sem_key = max(self.semesters.keys())
        current_semester = self.semesters[current_sem_key]
        
        if not current_semester.isFullTime:
            return "Not full-time"
            
        new_loan = Loan(amount)
        self.account.loans[new_loan.loan_id] = new_loan
        self.account.makePayment(amount)
        return "Completed!"

