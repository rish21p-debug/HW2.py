import random, os

class Course:
    '''
        >>> c1 = Course('CMPSC132', 'Programming in Python II', 3)
        >>> c2 = Course('CMPSC360', 'Discrete Mathematics', 3)
        >>> c1 == c2
        False
        >>> c3 = Course('CMPSC132', 'Programming in Python II', 3)
        >>> c1 == c3
        True
        >>> c1
        CMPSC132(3): Programming in Python II
        >>> c2
        CMPSC360(3): Discrete Mathematics
        >>> c3
        CMPSC132(3): Programming in Python II
        >>> c1 == None
        False
        >>> print(c1)
        CMPSC132(3): Programming in Python II
    '''
    def __init__(self, cid, cname, credits):
        # Task: Initialize a new course object.
        # Input: cid (str) - course id, cname (str) - course name, credits (int) - number of credits.
        # Output: None.
        # How program works: Saves the course ID, name, and credit amount to instance variables.
        self.cid = cid
        self.cname = cname
        self.credits = credits


    def __str__(self):
        # Task: Return a string representation of the course.
        # Input: None.
        # Output: A formatted string.
        # How: Returns a string combining the course ID, credits, and full title.
        return f"{self.cid}({self.credits}): {self.cname}"

    __repr__ = __str__

    def __eq__(self, other):
        # Task: Check if two course objects are the same.
        # Input: other - object to compare.
        # Output: Bool: True or False.
        # How: Checks if the other object is a Course, then compares their course IDs.
        if isinstance(other, Course):
            return self.cid == other.cid
        return False



class Catalog:
    ''' 
        >>> C = Catalog()
        >>> C.courseOfferings
        {}
        >>> C._loadCatalog("cmpsc_catalog_small.csv")
        >>> C.courseOfferings
        {'CMPSC 132': CMPSC 132(3): Programming and Computation II, 'MATH 230': MATH 230(4): Calculus and Vector Analysis, 'PHYS 213': PHYS 213(2): General Physics, 'CMPEN 270': CMPEN 270(4): Digital Design, 'CMPSC 311': CMPSC 311(3): Introduction to Systems Programming, 'CMPSC 360': CMPSC 360(3): Discrete Mathematics for Computer Science}
        >>> C.removeCourse('CMPSC 360')
        'Course removed successfully'
        >>> C.courseOfferings
        {'CMPSC 132': CMPSC 132(3): Programming and Computation II, 'MATH 230': MATH 230(4): Calculus and Vector Analysis, 'PHYS 213': PHYS 213(2): General Physics, 'CMPEN 270': CMPEN 270(4): Digital Design, 'CMPSC 311': CMPSC 311(3): Introduction to Systems Programming}
        >>> isinstance(C.courseOfferings['CMPSC 132'], Course)
        True
    '''

    def __init__(self):
        # Task: Initialize an empty course catalog.
        # Input: None.
        # Output: None.
        # How: Creates an empty dictionary to store course offerings using IDs as keys.
        self.courseOfferings = {}

    def addCourse(self, cid, cname, credits):
        # Task: Add a new course to the catalog list
        # Input: cid(course id) as a string, cname(course name) as a string, credits(number of credits) as an integer.
        # Output: A string that says whether it was a success or a duplicate course.
        # How: Checks if the course already exists, then adds it to the catalog if it doesn't.
        if cid in self.courseOfferings:
            return "Course already added"
        self.courseOfferings[cid] = Course(cid, cname, credits)
        return "Course added successfully"

    def removeCourse(self, cid):
        # Task: Remove a course from the catalog list
        # Input: cid(course id) as a string.
        # Output: A string that displays a success or failure message.
        # How: Checks if the course exists, then removes it from the catalog.
        if cid not in self.courseOfferings:
            return "Course not found"
        del self.courseOfferings[cid]
        return "Course removed successfully"

    def _loadCatalog(self, file):
        target_path = os.path.join(os.path.dirname(__file__), file)
        try:
            with open(target_path, "r") as f:
                course_info = f.readlines()
        except FileNotFoundError:
            course_info = []
        # Task: Load the course data from a CSV file.
        # Input: A file as a string
        # Output: None.
        # How: The function reads file lines, splits rows by commas, and calls addCourse for every entry.
        for line in course_info:
            cleaned_line = line.strip()
            if cleaned_line:
                parts = cleaned_line.split(",")
                if len(parts) >= 3:
                    cid = parts[0].strip()
                    cname = parts[1].strip()
                    credits = int(parts[2].strip())
                    self.addCourse(cid, cname, credits)
        


class Semester:
    '''
        >>> cmpsc131 = Course('CMPSC 131', 'Programming in Python I', 3)
        >>> cmpsc132 = Course('CMPSC 132', 'Programming in Python II', 3)
        >>> math230 = Course("MATH 230", 'Calculus', 4)
        >>> phys213 = Course("PHYS 213", 'General Physics', 2)
        >>> econ102 = Course("ECON 102", 'Intro to Economics', 3)
        >>> phil119 = Course("PHIL 119", 'Ethical Leadership', 3)
        >>> spr22 = Semester()
        >>> spr22
        No courses
        >>> spr22.addCourse(cmpsc132)
        >>> isinstance(spr22.courses['CMPSC 132'], Course)
        True
        >>> spr22.addCourse(math230)
        >>> spr22
        CMPSC 132; MATH 230
        >>> spr22.isFullTime
        False
        >>> spr22.totalCredits
        7
        >>> spr22.addCourse(phys213)
        >>> spr22.addCourse(econ102)
        >>> spr22.addCourse(econ102)
        'Course already added'
        >>> spr22.addCourse(phil119)
        >>> spr22.isFullTime
        True
        >>> spr22.dropCourse(phil119)
        >>> spr22.addCourse(Course("JAPNS 001", 'Japanese I', 4))
        >>> spr22.totalCredits
        16
        >>> spr22.dropCourse(cmpsc131)
        'No such course'
        >>> spr22.courses
        {'CMPSC 132': CMPSC 132(3): Programming in Python II, 'MATH 230': MATH 230(4): Calculus, 'PHYS 213': PHYS 213(2): General Physics, 'ECON 102': ECON 102(3): Intro to Economics, 'JAPNS 001': JAPNS 001(4): Japanese I}
    '''


    def __init__(self):
        # Task: Create a dictionary for courses in a semester.
        # Input: None.
        # Output: None.
        # How: Creates an empty dictionary to hold enrolled courses for the term.
        self.courses = {}



    def __str__(self):
        # Task: To convert current courses into a string.
        # Input: None.
        # Output: A joined string of course IDs.
        # How: Joins all the registered course keys with semicolons or returns 'No courses'.
        if not self.courses:
            return "No courses"
        return "; ".join(self.courses.keys())

    __repr__ = __str__

    def addCourse(self, course):
        # Task: Add a course instance to the current semester.
        # Input: course - Course object instance.
        # Output: Error string or None.
        # How: Prevents any duplicates by checking keys before updating dictionary.
        if course.cid in self.courses:
            return "Course already added"
        self.courses[course.cid] = course

    def dropCourse(self, course):
        # Task: Delete a course from the semester.
        # Input: course that needs to be dropped.
        # Output: Error string or None.
        # How: Removes the course key if it is in the dictionary.
        if course.cid not in self.courses:
            return "No such course"
        del self.courses[course.cid]

    @property
    def totalCredits(self):
        # Task: To count up total credits for the term.
        # Input: None.
        # Output: An integer value of credits.
        # How: Uses a for loop to go through all values in the course map and then sums up their credit properties.
        credit_sum = 0
        for c in self.courses.values():
            credit_sum += c.credits
        return credit_sum

    @property
    def isFullTime(self):
        # Task: Determine if a student meets full-time rules.
        # Input: None.
        # Output: Bool: True or False.
        # How: Checks if the total calculated credits are at least 12.
        return self.totalCredits >= 12

    
