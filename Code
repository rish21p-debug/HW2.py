class Person:
    '''
        >>> p1 = Person('Jason Lee', '204-99-2890')
        >>> p2 = Person('Karen Lee', '247-01-2670')
        >>> p1
        Person(Jason Lee, ***-**-2890)
        >>> p2
        Person(Karen Lee, ***-**-2670)
        >>> p3 = Person('Karen Smith', '247-01-2670')
        >>> p3
        Person(Karen Smith, ***-**-2670)
        >>> p2 == p3
        True
        >>> p1 == p2
        False
    '''

    def __init__(self, name, ssn):
        # Task: To set up a profile for a person.
        # Input: name (str), ssn (str).
        # Output: None.
        # How: Saves the name openly and hides the SSN in a private variable.
        self.name = name
        self.__ssn = ssn

    def __str__(self):
        # Task: Get a safe display string for the person.
        # Input: None.
        # Output: A redacted text string.
        # How: Uses just the last 4 digits of the private SSN to hide the full number.
        last_four = self.__ssn[-4:]
        return f"Person({self.name}, ***-**-{last_four})"

    __repr__ = __str__

    def get_ssn(self):
        # Task: To get the private SSN.
        # Input: None.
        # Output: The SSN as a string.
        # How: Returns the private SSN variable.
        return self.__ssn

    def __eq__(self, other):
        # Task: To check if two person objects are the same person.
        # Input: other which is the object to check against.
        # Output: A bool: true or false.
        # How: Checks if the other object is a Person, then compares their real SSNs.
        if isinstance(other, Person):
            return self.get_ssn() == other.get_ssn()
        return False

